{
  "name": "social-media",
  "version": "1.0.0",
  "private": true,
  "description": "Social media app monorepo (client + server)",
  "type": "module",
  "workspaces": [
    "app/client",
    "app/server"
  ],
  "scripts": {
    "client": "npm run client --workspace app/client",
    "server": "npm run server --workspace app/server",
    "dev": "concurrently -n client,server -c blue,green \"npm run client\" \"npm run server\"",
    "build": "npm run build --workspace app/client",
    "lint": "npm run lint --workspace app/client"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
