# Copy this file to .env and fill in real values. Never commit .env.

# MongoDB
DB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DATABASE=social_media

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS — frontend origin allowed to call the API / open sockets (no trailing slash).
# Local dev = http://localhost:5173. In production, your Vercel URL.
CLIENT_URL=http://localhost:5173

# Port — the host injects this automatically; defaults to 4000 locally.
# PORT=4000
